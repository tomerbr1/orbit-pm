{
  "name": "orbit",
  "version": "1.0.0",
  "description": "Fast orbit project management with time tracking, file operations, and orbit-auto loop integration. Replaces 5-10+ tool calls with single MCP calls.",
  "author": {
    "name": "Tomer Brami"
  },
  "homepage": "https://github.com/tomerbr1/claude-orbit",
  "repository": "https://github.com/tomerbr1/claude-orbit.git",
  "license": "MIT",
  "keywords": ["orbit", "task", "time-tracking", "context", "orbit-auto"],
  "mcpServers": {
    "pm": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from", "${CLAUDE_PLUGIN_ROOT}/mcp-server",
        "--with", "${CLAUDE_PLUGIN_ROOT}/orbit-db",
        "mcp-orbit"
      ]
    }
  }
}
